// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "auth"]
}

enum CareAccessStatus {
  PENDING_CARETAKER
  ACTIVE
  DECLINED
  REVOKED

  @@schema("public")
}

enum CareInvitationStatus {
  ACTIVE
  CLAIMED
  APPROVED
  EXPIRED
  REVOKED

  @@schema("public")
}

model AuthUser {
  id      String   @id @db.Uuid
  profile Profile?

  @@map("users")
  @@schema("auth")
}

model Profile {
  id        String    @id @db.Uuid
  name      String
  phone     String?   @unique
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")
  checkIns  CheckIn[]

  user AuthUser @relation(fields: [id], references: [id], onDelete: Cascade)

  caretakerRelationships CareRelationship[] @relation("CaretakerRelationships")
  memberRelationships    CareRelationship[] @relation("MemberRelationships")
  createdInvitations     CareInvitation[]   @relation("InvitationCaretaker")
  claimedInvitations     CareInvitation[]   @relation("InvitationClaimant")
  endedAccessPeriods     CareAccessPeriod[] @relation("EndedAccessPeriods")

  @@map("profiles")
  @@schema("public")
}

model CareRelationship {
  id          String   @id @default(uuid()) @db.Uuid
  caretakerId String   @map("caretaker_id") @db.Uuid
  memberId    String   @map("member_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  caretaker Profile @relation("CaretakerRelationships", fields: [caretakerId], references: [id], onDelete: Cascade)
  member    Profile @relation("MemberRelationships", fields: [memberId], references: [id], onDelete: Cascade)

  accessPeriods CareAccessPeriod[]

  @@unique([caretakerId, memberId])
  @@index([caretakerId])
  @@index([memberId])
  @@map("care_relationships")
  @@schema("public")
}

model CareAccessPeriod {
  id             String           @id @default(uuid()) @db.Uuid
  relationshipId String           @map("relationship_id") @db.Uuid
  status         CareAccessStatus @default(PENDING_CARETAKER)
  startedAt      DateTime         @default(now()) @map("started_at")
  endedAt        DateTime?        @map("ended_at")
  endedById      String?          @map("ended_by_id") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  relationship CareRelationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  endedBy      Profile?         @relation("EndedAccessPeriods", fields: [endedById], references: [id], onDelete: SetNull)

  @@index([relationshipId])
  @@index([relationshipId, status])
  @@map("care_access_periods")
  @@schema("public")
}

model CareInvitation {
  id          String               @id @default(uuid()) @db.Uuid
  caretakerId String               @map("caretaker_id") @db.Uuid
  claimedById String?              @map("claimed_by_id") @db.Uuid
  codeHash    String               @unique @map("code_hash")
  status      CareInvitationStatus @default(ACTIVE)
  expiresAt   DateTime             @map("expires_at")
  claimedAt   DateTime?            @map("claimed_at")
  createdAt   DateTime             @default(now()) @map("created_at")

  caretaker Profile  @relation("InvitationCaretaker", fields: [caretakerId], references: [id], onDelete: Cascade)
  claimedBy Profile? @relation("InvitationClaimant", fields: [claimedById], references: [id], onDelete: SetNull)

  @@index([caretakerId, status])
  @@index([expiresAt])
  @@map("care_invitations")
  @@schema("public")
}

model CheckIn {
  id             String   @id @default(uuid()) @db.Uuid
  memberId       String   @db.Uuid
  generalFeeling Int
  notes          String?
  submittedAt    DateTime @default(now()) @map("submitted_at")

  member Profile @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("check_ins")
  @@schema("public")
}
